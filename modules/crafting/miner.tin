#class {minebot} {kill};
#class {minebot} {open};
#echo {<ffa>====================================================================<088>};
#echo {<fff>  3kdb MinerBot  quick start<088>};
#echo {};
#echo {<ccd>Ore<fff>  Walks mine paths and sends <dce>mine <deposit><fff> when that ore appears.<088>};
#echo {<fff>  Example: <dce>mine gold obsidian adamantium<088>};
#echo {<ccd>  All deposit names: <fff>mine-list<088>};
#echo {};
#echo {<ccd>Jewels<fff>  Sends <dce>mine for <name><fff> when that tier matches. Requires miner mskill.<088>};
#echo {<fff>  Example one jewel: <dce>minefor aquamarine dust<088>};
#echo {<fff>  Example rotate list: <dce>minefor emerald dust,emerald,sapphire<088>};
#echo {<ccd>  All jewel names by ore tier: <fff>minefor-list<088>};
#echo {};
#echo {<ccd>Stop bots<fff>  miner-off <ccd>then <fff>miner-on<ccd> to load again.<088>};
#echo {<ffa>====================================================================<088>};

#alias {mine-list} {
    #echo {<ccd>Deposits for <dce>mine <deposit> ...<ccd>:<088>};
    #echo {<fff>copper bronze iron steel silver gold mithril titanium ebon<088>};
    #echo {<fff>adamantium obsidian nethernium voidstone phasemetal chaostone<088>};
};

#var mine_levels {};
#var num_levels {};
#var curr_level 1;
#var mine[copper] 0;
#var mine[bronze] 0;
#var mine[iron] 0;
#var mine[steel] 0;
#var mine[silver] 0;
#var mine[gold] 0;
#var mine[mithril] 0;
#var mine[titanium] 0;
#var mine[ebon] 0;
#var mine[adamantium] 0;
#var mine[obsidian] 0;
#var mine[nethernium] 0;
#var mine[voidstone] 0;
#var mine[phasemetal] 0;
#var mine[chaostone] 0;

#alias {mine %0} {
	#regex {%0} {copper} {#var mine[copper] 1};
	#regex {%0} {bronze} {#var mine[bronze] 1};
	#regex {%0} {iron} {#var mine[iron] 1};
	#regex {%0} {steel} {#var mine[steel] 1};
	#regex {%0} {silver} {#var mine[silver] 1};
	#regex {%0} {gold} {#var mine[gold] 1};
	#regex {%0} {mithril} {#var mine[mithril] 1};
	#regex {%0} {titanium} {#var mine[titanium] 1};
	#regex {%0} {ebon} {#var mine[ebon] 1};
	#regex {%0} {adamantium} {#var mine[adamantium] 1};
	#regex {%0} {obsidian} {#var mine[obsidian] 1};
	#regex {%0} {nethernium} {#var mine[nethernium] 1};
	#regex {%0} {voidstone} {#var mine[voidstone] 1};
	#regex {%0} {phasemetal} {#var mine[phasemetal] 1};
	#regex {%0} {chaostone} {#var mine[chaostone] 1};

	#if {$mine[copper]} {#list mine_levels add 1};
	#if {$mine[bronze]} {#list mine_levels add 2};
	#if {$mine[iron] | $mine[steel]} {#list mine_levels add 3};
	#if {$mine[silver] | $mine[gold] | $mine[mithril]} {#list mine_levels add 4};
	#if {$mine[titanium] | $mine[ebon]} {#list mine_levels add 5};
	#if {$mine[adamantium] | $mine[obsidian]} {#list mine_levels add 6};
	#if {$mine[nethernium] | $mine[voidstone] | $mine[phasemetal]} {#list mine_levels add 7};
	#if {$mine[chaostone]} {#list mine_levels add 8};
	
	#list mine_levels size num_levels;
	#var curr_level 1;
	#path load ${mine$mine_levels[${curr_level}]};
	miner;
	#var {_miner_path_driver} {ore};
	_step_room;
}

#var deposit 0;

#alias {miner} {
	#class {miner} {open};
	#act {{(A|You have found a deposit of) \w+ ore( deposit.|!)}} {
		#undelay minewalk;
		#regex {%%1} {copper} {#if {$mine[copper]} {mine} {_step_room}};
		#regex {%%1} {bronze} {#if {$mine[bronze]} {mine} {_step_room}};
		#regex {%%1} {iron} {#if {$mine[iron]} {mine} {_step_room}};
		#regex {%%1} {steel} {#if {$mine[steel]} {mine} {_step_room}};
		#regex {%%1} {silver} {#if {$mine[silver]} {mine} {_step_room}};
		#regex {%%1} {gold} {#if {$mine[gold]} {mine} {_step_room}};
		#regex {%%1} {mithril} {#if {$mine[mithril]} {mine} {_step_room}};
		#regex {%%1} {titanium} {#if {$mine[titanium]} {mine} {_step_room}};
		#regex {%%1} {ebon} {#if {$mine[ebon]} {mine} {_step_room}};
		#regex {%%1} {adamantium} {#if {$mine[adamantium]} {mine} {_step_room}};
		#regex {%%1} {obsidian} {#if {$mine[obsidian]} {mine} {_step_room}};
		#regex {%%1} {nethernium} {#if {$mine[nethernium]} {mine} {_step_room}};
		#regex {%%1} {voidstone} {#if {$mine[voidstone]} {mine} {_step_room}};
		#regex {%%1} {phasemetal} {#if {$mine[phasemetal]} {mine} {_step_room}};
		#regex {%%1} {chaostone} {#if {$mine[chaostone]} {mine} {_step_room}};
	} {1};
	
	#action {^You begin to mine} {#undelay minewalk} {1};
	#NOP #action {^You have exhausted the supply of } {get all;_step_room} {1};
	#NOP the action capture below is much more reliable;
	#action {^You have exhausted} {get all;_step_room} {1};
	#action {^It appears this part of the shaft has already been searched.} {_step_room} {1};
	#action {^You have found nothing.} {_step_room} {1};
	#action {^You are not skilled enough to mine this.} {_step_room} {1};
	#action {^You should try to mine this instead.} {mine} {1};
	#action {^You cannot spelunk while you're being attacked!} {#line oneshot #action {dealt the killing blow} {corpse_trig;spelunk} {1};};
	#action {^You cannot mine while you're being attacked!} {#line oneshot #action {dealt the killing blow} {corpse_trig;mine} {1};};
	#action {^You have disturbed %*} {
		#undelay minewalk;
		#line oneshot #action {dealt the killing blow} {
			corpse_trig;
			spelunk;
		} {1};
	} {1};

	#alias {_check_mine} {spelunk};
	#alias {_step_room} {#delay minewalk {#path walk;_check_mine} {1}};
	
	#class {miner} {close};
};

#alias {killbot} {#undelay minewalk;#class {miner} {kill}};
#class {minebot} {close};

#VARIABLE {mine1} {mines 1;se;e;n;n;e;se;nw;w;s;w;e;s;e;w;s;se;sw;s;s;n;n;e;e;w;w;ne;nw;sw;w;w;n;s;e;sw;s;s;nw;n;w;s;n;e;s;se;n;n;ne;e;ne;n;w;nw;out};
#VARIABLE {mine2} {mines 2;se;e;n;n;e;se;nw;w;s;w;e;s;e;w;s;se;sw;s;s;n;n;e;e;w;w;ne;nw;sw;w;w;n;s;e;sw;s;s;nw;n;w;s;n;e;s;se;n;n;ne;e;ne;n;w;nw;exit};
#VARIABLE {mine3} {mines 3;n;e;s;e;n;n;n;n;n;se;n;e;nw;se;ne;sw;n;nw;se;n;s;ne;se;n;s;ne;sw;s;ne;sw;e;s;w;e;s;w;w;n;n;w;w;s;e;s;s;e;e;w;sw;se;nw;s;n;sw;ne;w;e;nw;se;e;e;s;s;exit};
#VARIABLE {mine4} {mines 4;e;e;e;se;se;se;ne;ne;ne;nw;nw;nw;sw;sw;sw;e;e;e;e;e;w;w;n;n;s;s;s;s;s;nw;nw;nw;w;ne;ne;ne;ne;se;se;se;se;sw;sw;sw;sw;nw;nw;nw;nw;w;se;se;se;se;se;ne;ne;ne;ne;ne;nw;nw;nw;nw;nw;sw;sw;sw;sw;ne;ne;ne;ne;se;se;se;se;n;n;exit};
#VARIABLE {mine5} {mines 5;e;n;n;n;e;se;se;e;e;ne;e;s;s;w;s;e;e;w;w;s;nw;nw;e;w;s;s;s;s;w;n;n;n;sw;sw;w;n;n;n;w;exit};
#VARIABLE {mine6} {mines 6;w;w;w;sw;n;s;s;s;sw;se;ne;nw;s;n;n;n;e;n;n;e;e;n;n;w;s;nw;s;w;w;w;n;s;s;e;e;e;e;se;e;exit};
#VARIABLE {mine7} {mines 7;se;e;n;e;e;e;e;s;w;w;s;e;s;e;s;s;w;w;w;n;n;e;s;n;w;s;s;e;e;e;e;e;e;n;n;w;s;n;e;s;s;w;w;w;n;n;e;n;e;n;w;w;n;w;w;w;w;w;s;nw;exit};
#VARIABLE {mine8} {mines 8;s;w;w;sw;se;se;n;n;s;s;ne;ne;nw;n;exit};

#class {jewelminebot} {kill};
#class {jewelminebot} {open};

#alias {killjewelbot} {#undelay jminewalk;#class jewelminer kill};

#alias {minefor-list} {
    #echo {<ccd>Jewels for <dce>minefor<ccd> (match ore tier on deposit):<088>};
    #echo {<ccd>copper:<fff> copper shards, aquamarine, aquamarine dust, morganite, morganite dust, tiger's eye, tiger's eye dust<088>};
    #echo {<ccd>bronze:<fff> bronze shards, cat's eye, cat's eye dust, eye of flame, garnet, garnet dust<088>};
    #echo {<ccd>iron:<fff> iron shards, garnet, garnet dust, alexandrite, alexandrite dust, eye of frost<088>};
    #echo {<ccd>steel:<fff> steel shards, eye of frost, eye of flame, cat's eye, cat's eye dust<088>};
    #echo {<ccd>silver:<fff> silver shards, pyrite, pyrite dust, tourmaline, tourmaline dust, beryl, beryl dust, eye of earth, roan's tears<088>};
    #echo {<ccd>gold:<fff> gold shards, eye of air, topaz, topaz dust, amethyst, amethyst dust, happy ed's tears<088>};
    #echo {<ccd>mithril:<fff> mithril shards, heliodor, heliodor dust, hematite, hematite dust, core of flame<088>};
    #echo {<ccd>titanium:<fff> titanium shards, peridot, peridot dust, core of frost<088>};
    #echo {<ccd>ebon:<fff> ebon shards, core of earth, heliodor, heliodor dust, peridot, peridot dust<088>};
    #echo {<ccd>adamantium:<fff> adamantium shards, core of air, pearl, pearl dust<088>};
    #echo {<ccd>obsidian:<fff> obsidian shards, ghoti's tears, opal, opal dust, pearl, pearl dust<088>};
    #echo {<ccd>nethernium:<fff> nethernium shards, ghoti's tears, opal, opal dust, star of flame<088>};
    #echo {<ccd>voidstone:<fff> voidstone shards, shansabyk's tears, diamond, diamond dust, star of frost<088>};
    #echo {<ccd>phasemetal:<fff> phasemetal shards, emerald, emerald dust, sapphire, sapphire dust, star of earth, star of air<088>};
    #echo {<ccd>chaostone:<fff> chaostone shards, cancer's tears, emerald, emerald dust, ruby, ruby dust, sapphire, sapphire dust<088>};
};


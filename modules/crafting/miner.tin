#alias {.jewel_queue_bump} {
    #list jewel_target_queue size _jqsz;
    #math jewel_queue_idx {$jewel_queue_idx + 1};
    #if {$jewel_queue_idx > $_jqsz} {#var jewel_queue_idx 1};
};

#alias {.jewel_try_queue_pick} {
    #list jewel_target_queue size _jqsz;
    #if {$_jqsz > 0} {
        #list jewel_target_queue get $jewel_queue_idx _jkey;
        #replace {_jkey} {\r} {};
        #replace {_jkey} {\n} {};
        #format _jkey {%p} {$_jkey};
        #var _jewel_phrase_key $_jkey;
        .jewel_phrase_from_key;
        #if {"$jewel_mud_phrase" != ""} {.jewel_queue_bump};
    };
};


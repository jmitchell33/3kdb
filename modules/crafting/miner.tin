#alias {.minefor_parse_comma_segments} {
    #var _mf_scratch $_mf_spec;
    #replace {_mf_scratch} {,} {~};
    #list _mf_seglist clear;
    #list _mf_seglist explode {~} {$_mf_scratch};
    #loop 1 &_mf_seglist[] _mf_li {
        #list _mf_seglist get $_mf_li _mf_seg;
        #format _mf_seg {%p} {$_mf_seg};
        #format _mf_seg {%l} {$_mf_seg};
        #if {"$_mf_seg" != ""} {#var minefor_parse_input $_mf_seg;#var _mf_seg_done 0;minefor_apply_one_jewel_string};
    };
};

#alias {minefor} {
    #format _mf_arg {%l} {%0};
    #if {"$_mf_arg" == ""} {#nop} {
        killbot;
        killjewelbot;
        minefor_clear_jewel_flags;
        #var jewel_queue_idx 1;
        #var _mf_spec %0;
        #format _mf_spec {%l} {$_mf_spec};
        #replace {_mf_spec} {, } {,};
        #replace {_mf_spec} { ,} {,};
        #replace {_mf_spec} {，} {,};
        .minefor_parse_comma_segments;
        #list jewel_mine_levels clear;
        #var jewel_curr_level 1;
        #if {$mine_jewel[copper_shards] | $mine_jewel[aquamarine] | $mine_jewel[aquamarine_dust] | $mine_jewel[morganite] | $mine_jewel[morganite_dust] | $mine_jewel[tigers_eye] | $mine_jewel[tigers_eye_dust]} {#list jewel_mine_levels add 1};
        #if {$mine_jewel[bronze_shards] | $mine_jewel[cats_eye] | $mine_jewel[cats_eye_dust] | $mine_jewel[eye_of_flame] | $mine_jewel[garnet] | $mine_jewel[garnet_dust]} {#list jewel_mine_levels add 2};
        #if {$mine_jewel[iron_shards] | $mine_jewel[garnet] | $mine_jewel[garnet_dust] | $mine_jewel[alexandrite] | $mine_jewel[alexandrite_dust] | $mine_jewel[eye_of_frost] | $mine_jewel[steel_shards] | $mine_jewel[eye_of_flame] | $mine_jewel[cats_eye] | $mine_jewel[cats_eye_dust]} {#list jewel_mine_levels add 3};
        #if {$mine_jewel[silver_shards] | $mine_jewel[pyrite] | $mine_jewel[pyrite_dust] | $mine_jewel[tourmaline] | $mine_jewel[tourmaline_dust] | $mine_jewel[beryl] | $mine_jewel[beryl_dust] | $mine_jewel[eye_of_earth] | $mine_jewel[roans_tears] | $mine_jewel[gold_shards] | $mine_jewel[eye_of_air] | $mine_jewel[topaz] | $mine_jewel[topaz_dust] | $mine_jewel[amethyst] | $mine_jewel[amethyst_dust] | $mine_jewel[happy_eds_tears] | $mine_jewel[mithril_shards] | $mine_jewel[heliodor] | $mine_jewel[heliodor_dust] | $mine_jewel[hematite] | $mine_jewel[hematite_dust] | $mine_jewel[core_of_flame]} {#list jewel_mine_levels add 4};
        #if {$mine_jewel[titanium_shards] | $mine_jewel[peridot] | $mine_jewel[peridot_dust] | $mine_jewel[core_of_frost] | $mine_jewel[ebon_shards] | $mine_jewel[core_of_earth] | $mine_jewel[heliodor] | $mine_jewel[heliodor_dust] | $mine_jewel[peridot] | $mine_jewel[peridot_dust]} {#list jewel_mine_levels add 5};
        #if {$mine_jewel[adamantium_shards] | $mine_jewel[core_of_air] | $mine_jewel[pearl] | $mine_jewel[pearl_dust] | $mine_jewel[obsidian_shards] | $mine_jewel[ghotis_tears] | $mine_jewel[opal] | $mine_jewel[opal_dust]} {#list jewel_mine_levels add 6};
        #if {$mine_jewel[nethernium_shards] | $mine_jewel[ghotis_tears] | $mine_jewel[opal] | $mine_jewel[opal_dust] | $mine_jewel[star_of_flame] | $mine_jewel[voidstone_shards] | $mine_jewel[shansabyks_tears] | $mine_jewel[diamond] | $mine_jewel[diamond_dust] | $mine_jewel[star_of_frost] | $mine_jewel[phasemetal_shards] | $mine_jewel[emerald] | $mine_jewel[emerald_dust] | $mine_jewel[sapphire] | $mine_jewel[sapphire_dust] | $mine_jewel[star_of_earth] | $mine_jewel[star_of_air]} {#list jewel_mine_levels add 7};
        #if {$mine_jewel[chaostone_shards] | $mine_jewel[cancers_tears] | $mine_jewel[emerald] | $mine_jewel[emerald_dust] | $mine_jewel[ruby] | $mine_jewel[ruby_dust] | $mine_jewel[sapphire] | $mine_jewel[sapphire_dust]} {#list jewel_mine_levels add 8};
        #list jewel_mine_levels size jewel_num_levels;
        #if {$jewel_num_levels < 1} {
            #echo {<eaa>minefor: no matching jewels in <fff>%0<eaa>. Try <fff>minefor-list<eaa> after <fff>miner-on<eaa>.<088>};
        } {
            #path load ${mine$jewel_mine_levels[${jewel_curr_level}]};
            jewelminer;
            #var {_miner_path_driver} {jewel};
            _step_jewel_room;
        };
    };
};

#alias {.jewel_send_mine_cmd} {
    #if {"$jewel_mud_phrase" != ""} {
        #var jewel_mud_phrase_last $jewel_mud_phrase;
        #var _jewel_out {};
        #cat {_jewel_out} {mine for };
        #cat {_jewel_out} $jewel_mud_phrase;
        #send $_jewel_out;
    } {
        _step_jewel_room;
    };
};
#alias {jewelm} {
    #if {"$jewel_mud_phrase" == ""} {#var jewel_mud_phrase $jewel_mud_phrase_last};
    .jewel_send_mine_cmd;
};
#alias {.jewel_send_or_spelunk} {.jewel_send_mine_cmd};

#alias {.jewel_pick_copper} {
    #var _jewel_ore {copper};
    #var jewel_mud_phrase {};
    .jewel_try_queue_pick;
    #if {"$jewel_mud_phrase" == ""} {
        #if {$mine_jewel[copper_shards]} {#var jewel_mud_phrase {copper shards}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[aquamarine]} {#var jewel_mud_phrase {aquamarine}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[aquamarine_dust]} {#var jewel_mud_phrase {aquamarine dust}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[morganite]} {#var jewel_mud_phrase {morganite}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[morganite_dust]} {#var jewel_mud_phrase {morganite dust}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[tigers_eye]} {#var jewel_mud_phrase {tiger's eye}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[tigers_eye_dust]} {#var jewel_mud_phrase {tiger's eye dust}};
    };
    .jewel_send_or_spelunk;
};

#alias {.jewel_pick_bronze} {
    #var _jewel_ore {bronze};
    #var jewel_mud_phrase {};
    .jewel_try_queue_pick;
    #if {"$jewel_mud_phrase" == ""} {
        #if {$mine_jewel[bronze_shards]} {#var jewel_mud_phrase {bronze shards}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[cats_eye]} {#var jewel_mud_phrase {cat's eye}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[cats_eye_dust]} {#var jewel_mud_phrase {cat's eye dust}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[eye_of_flame]} {#var jewel_mud_phrase {eye of flame}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[garnet]} {#var jewel_mud_phrase {garnet}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[garnet_dust]} {#var jewel_mud_phrase {garnet dust}};
    };
    .jewel_send_or_spelunk;
};

#alias {.jewel_pick_iron} {
    #var _jewel_ore {iron};
    #var jewel_mud_phrase {};
    .jewel_try_queue_pick;
    #if {"$jewel_mud_phrase" == ""} {
        #if {$mine_jewel[iron_shards]} {#var jewel_mud_phrase {iron shards}};
        #if {"$jewel_mud_phrase" == "" && $mine_jewel[garnet]} {#var jewel_mud_phrase {garnet}};

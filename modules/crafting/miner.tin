#alias {jewelminer} {
    #class {jewelminer} {open};
    #act {{(A|You have found a deposit of) \w+ ore( deposit.|!)}} {
        #undelay jminewalk;
        #regex {%%1} {copper} {.jewel_pick_copper};
        #regex {%%1} {bronze} {.jewel_pick_bronze};
        #regex {%%1} {iron} {.jewel_pick_iron};
        #regex {%%1} {steel} {.jewel_pick_steel};
        #regex {%%1} {silver} {.jewel_pick_silver};
        #regex {%%1} {gold} {.jewel_pick_gold};
        #regex {%%1} {mithril} {.jewel_pick_mithril};
        #regex {%%1} {titanium} {.jewel_pick_titanium};
        #regex {%%1} {ebon} {.jewel_pick_ebon};
        #regex {%%1} {adamantium} {.jewel_pick_adamantium};
        #regex {%%1} {obsidian} {.jewel_pick_obsidian};
        #regex {%%1} {nethernium} {.jewel_pick_nethernium};
        #regex {%%1} {voidstone} {.jewel_pick_voidstone};
        #regex {%%1} {phasemetal} {.jewel_pick_phasemetal};
        #regex {%%1} {chaostone} {.jewel_pick_chaostone};
    } {1};
    #action {^You begin to mine} {#undelay jminewalk} {1};
    #action {^You have exhausted} {get all;_step_jewel_room} {1};
    #action {^It appears this part of the shaft has already been searched.} {_step_jewel_room} {1};
    #action {^You have found nothing.} {_step_jewel_room} {1};
    #action {^You are not skilled enough to mine this.} {_step_jewel_room} {1};
    #action {^You should try to mine this instead.} {jewelm} {1};
    #action {^You cannot spelunk while you're being attacked!} {#line oneshot #action {dealt the killing blow} {corpse_trig;spelunk} {1};};
    #action {^You cannot mine while you're being attacked!} {#line oneshot #action {dealt the killing blow} {corpse_trig;jewelm} {1};};
    #action {^You have disturbed %*} {
        #undelay jminewalk;
        #line oneshot #action {dealt the killing blow} {corpse_trig;spelunk} {1};
    } {1};
    #alias {_check_jewelmine} {spelunk};
    #alias {_step_jewel_room} {#delay jminewalk {#path walk;_check_jewelmine} {1}};
    #class {jewelminer} {close};
};

#class {jewelminebot} {close};

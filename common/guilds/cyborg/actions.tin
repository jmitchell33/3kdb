#class {guild_actions} {kill}
#class {guild_actions} {open}

#NOP --- GUILD SPECIFIC ACTIONS;

#action {^A dark and imposing cloud forms as trillions of nanoscopic} {
    #var mob[nano] 1;
    #if {$gags[combat_guild]} {#line gag 5};
} {2};

#action {^The nanite deconstructors erode %* defenses!$} {#if {$gags[combat_guild]} {#line gag}} {2};

#class {guild_actions} {close}
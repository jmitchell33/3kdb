#class {3kdb_library} {kill}
#class {3kdb_library} {open}

#NOP -- 3kdb alias library with separated listing and description features;

#alias format_3kdblibrary {
    #format {command_name} {  <cff>%-20s  <deb>%-60s<088>} {%1} {%2};
    #echo $command_name;
};

#alias format_3kdblibrary1 {
    #format {command_name} {  <cff>%-20s<088>} {%1};
    #echo $command_name;
};

#alias library3kdb {
    #NOP Reset variables;
    #var tempflag 0;
    #var number &library3kdb[];

    #NOP Display header;
    #echo {<ccf>  -------<088>           <ffa>3kdb<088>           <ccf>-------<088>};
    #echo {<ccf>  -------    <ffa>ALIAS LIBRARY<088> <fff>($number)<088>  <ccf>-------    <088>};
    #echo {<ceb>       For more info: 3kdbinfo <alias> <088>};
    #echo {<cfc>  Sort using filters: library3kdb <filter> <088>};
    #echo {    <fff>Filters:  <eaf>eternal rolm crafting mapping<088>};
    #echo {                <eaf>chaos fantasy science guild misc<088>};
    #echo {                   <eaf>corpse combat profession debug<088>};
    #echo {                      <eaf>trackers bot mip<088>};
    #echo {<ccf>  ---------------------------------------    <088>};
    #echo {<ceb> Use <bca>library3kdb1<ceb> for all aliases without description<088>};
    #echo {};

    #NOP Sort and display aliases with descriptions;
    #list library3kdb index name;
    #list library3kdb sort;
    format_3kdblibrary {Alias} {Description};
    #foreach $library3kdb[%*] index {
        #regexp {"%1"} {"$index[type]"} {
            #var tempflag 1;
            format_3kdblibrary {$index[name]} {$index[desc]};
        };
    };
    #if !$tempflag {
        #foreach $library3kdb[%*] index {
            format_3kdblibrary {$index[name]} {$index[desc]};
        };
    };
};

#alias library3kdb1 {
    #NOP Reset variables;
    #var tempflag 0;
    #var number &library3kdb[];

    #NOP Display header;
    #echo {<ccf>  -------<088>           <ffa>3kdb<088>           <ccf>-------<088>};
    #echo {<ccf>  -------    <ffa>ALIAS LIBRARY<088> <fff>($number)<088>  <ccf>-------    <088>};
    #echo {<ceb>       For more info: 3kdbinfo <alias> <088>};
    #echo {<cfc>  Sort using filters: library3kdb <filter> <088>};
    #echo {    <fff>Filters:  <eaf>eternal rolm crafting mapping<088>};
    #echo {                <eaf>chaos fantasy science guild misc<088>};
    #echo {                   <eaf>corpse combat profession debug<088>};
    #echo {                      <eaf>trackers bot mip<088>};
    #echo {<ccf>  ---------------------------------------    <088>};
    #echo {<ceb> Use <bca>library3kdb<ceb> for all aliases + description<088>};
    #echo {};

    #NOP Sort and display aliases without descriptions;
    #list library3kdb index name;
    #list library3kdb sort;
    format_3kdblibrary1 {Alias};
    #foreach $library3kdb[%*] index {
        #regexp {"%1"} {"$index[type]"} {
            #var tempflag 1;
            format_3kdblibrary1 {     $index[name]};
        };
    };
    #if !$tempflag {
        #foreach $library3kdb[%*] index {
            format_3kdblibrary1 {     $index[name]};
        };
    };
};

#NOP Check if alias exists in library3kdb and display info;
#alias 3kdbinfo {
    #var alias_found 0;
    #foreach $library3kdb[%*] index {
        #if {"%0" == "$index[name]"} {
            #echo {<faa>===========================<088>};
            #echo {<bea>Filter: <eaf>$index[type]<088>};
            #if {&{index[area]}} {
                #echo {<bea>Area: <dae>$index[area]<088>};
            };
            #if {&{index[item]}} {
                #echo {<bea>Item: <efb>$index[item]<088>};
            };
            #if {&{index[affects]}} {
                #echo {<bea>Affects: <efa>$index[affects]<088>};
            };
            #if {&{index[prof]}} {
                #echo {<bea>Profession: <efb>$index[prof]<088>};
            };
            #if {&{index[spell]}} {
                #echo {<bea>Spell: <dae>$index[spell]<088>};
            };
            #if {&{index[ctg]}} {
                #echo {<bea>Category: <efb>$index[ctg]<088>};
            };            
            #echo {<bea>Alias: <ccf>$index[name]<088>};
            #echo {<bea>Usage: <ceb>$index[usage]<088>};
            #echo {<bea>Description: <fff>$index[desc]<088>};
            #if {&{index[helpfile]}} {
                #echo {<bea>Help File: <ccd>$index[helpfile]<088>};
            };
            #echo {<bea>Location:<088> $index[location]};
            #echo {<faa>===========================<088>};
            #var alias_found 1;
        };
    };
    #if !$alias_found {
        #echo {<fff>Alias not found: <088>%0};
    };
};


#list library3kdb clear;

#NOP -------------------------- Eternal Aliases ----------------------------------;

#list library3kdb add {{{name} {dupe} {type} {eternal} {desc} {duplicate items} {usage} {dupe <item>} {helpfile} {(info duplicate item} {location} {common/guilds/eternal/eternal.tin}}};

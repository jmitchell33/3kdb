#list library3kdb add {{{name} {dstats} {type} {trackers} {desc} {damage tracking report - requires numbers vaf perk} {usage} {'dstats'} {location} {modules/dmgtracker/dmgtracker.tin}}};
#list library3kdb add {{{name} {dreset} {type} {trackers} {desc} {reset damage tracker} {usage} {'dreset'} {location} {modules/dmgtracker/dmgtracker.tin}}};
#list library3kdb add {{{name} {truckDmg-clear} {type} {trackers} {desc} {reset truck damage tracking} {usage} {'truckDmg-clear'} {location} {modules/dmgtracker/dmgtracker_jugger.tin}}};
#list library3kdb add {{{name} {mountDmg-clear} {type} {trackers} {desc} {reset mount damage tracking} {usage} {'mountDmg-clear'} {location} {modules/dmgtracker/dmgtracker_jugger.tin}}};
#list library3kdb add {{{name} {supportDmg-clear} {type} {trackers} {desc} {reset support mech damage tracking} {usage} {'supportDmg-clear'} {location} {modules/dmgtracker/dmgtracker_jugger.tin}}};
#list library3kdb add {{{name} {defStats} {type} {trackers} {desc} {defense tracking report} {usage} {'defStats'} {location} {modules/defense_tracker/defense_tracker.tin}}};
#list library3kdb add {{{name} {istats} {type} {trackers} {desc} {item tracker extraordinaire} {usage} {'istats'} {location} {common/eq/item_tracker.tin}}};
#list library3kdb add {{{name} {istats_reset} {type} {trackers} {desc} {reset item tracker} {usage} {'istats_reset'} {location} {common/eq/item_tracker.tin}}};
#list library3kdb add {{{name} {defStats_reset} {type} {trackers} {desc} {reset defense stats tracker} {usage} {'defStats_reset'} {location} {modules/defense_tracker/defense_tracker.tin}}};
#list library3kdb add {{{name} {spellDmg-clear} {type} {trackers} {desc} {clear spell damage tracker} {usage} {'spellDmg-clear'} {location} {modules/dmgtracker/dmgtracker_mage.tin}}};
#list library3kdb add {{{name} {3kReport-config} {type} {trackers} {desc} {configure kill report options} {usage} {'3kReport-config'} {location} {common/3kReport.tin}}};
#list library3kdb add {{{name} {3kReport+} {type} {trackers} {desc} {add kill report filter} {usage} {'3kReport+'} {location} {common/3kReport.tin}}};
#list library3kdb add {{{name} {3kReport-} {type} {trackers} {desc} {remove kill report filter} {usage} {'3kReport-'} {location} {common/3kReport.tin}}};

#class {3kdb_library} {close}
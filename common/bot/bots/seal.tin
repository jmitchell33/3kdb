#action {You let go of the cliff face and float upward.} {
    #if {$bot[step] > 100} {
        #NOP;
    } {
        #var bot[step] 70;
        #map goto 31838;
        #delay 5 {..};
    };
} {1};

#action {^You begin climbing, but soon slip on a patch of ice and plummet} {
    #if {$bot[step] < 75} {
        .pause;
        #map goto 37520;
        #20 {u};
        #var bot[step] 70;
        #map goto 31838;
        #delay 5 {..};
    } {
        #NOP -- If less than 100, you still need to do the water nymphs;
        #NOP -- If not, it's clear so move onto past the waterfall;
        #if {$bot[step] < 100} {
            .pause;
            #map goto 37520;
            #var bot[step] 102;
            #delay 5 {..};
        } {
            .pause;
            #20 {u};
            #var bot[step] 195;
            #map goto 31838;
            #delay 5 {..};
        };
    };
} {1};

#action {^An arena gate opens and you exit the arena.} {#map goto 46464;..} {1};
#action {^YOu HaVE ALrEadY DOnE ThIS TyPE OF BAttLE ToDAY.} {#map goto 46464;..} {1};

#class {bot} {close}
#read common/bot/generic.tin
#alias {.check_sarcophagus} {
    examine sarcophagus;
    search sarcophagus;
    glance
};

#action {^You start up the stairs, but stop as a voice booms:} {mapUndo};
#action {^As you move toward the stairs, the stone statues move to stop you!} {mapUndo};

#NOP A shadow demon silently materializes from the darkness!;

